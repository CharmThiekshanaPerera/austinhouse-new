# ── Backend Environment Variables ─────────────────────────────────────────────
# Copy this to .env and fill in your real values before deploying

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name
MONGODB_DB=austinhouse

# CORS — comma-separated list of allowed frontend origins
# Replace with your real Vercel URL after deployment
ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# JWT — MUST change this to a long, random secret in production!
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
